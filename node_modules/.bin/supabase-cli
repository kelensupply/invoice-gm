#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules/supabase-cli/dist/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules/supabase-cli/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules/supabase-cli/dist/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules/supabase-cli/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/supabase-cli@0.0.21/node_modules:/home/msj/Desktop/invoice-gm/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../supabase-cli/dist/index.js" "$@"
else
  exec node  "$basedir/../supabase-cli/dist/index.js" "$@"
fi
